---
// FlightMap.astro
// Requires: npm install leaflet
// Requires: npm install -D @types/leaflet (for TypeScript)
const hikingColor = '#8856fc';
const flyingColor = '#001bff';
---

<div id="flight-map" class="w-full h-96 rounded-lg border border-gray-200 bg-gray-100 hidden"></div>
<div id="flight-map-label" data-hikingc={hikingColor} data-flyingc={flyingColor} class="w-full text-center hidden">
  <span class = "font-bold" style={`color: ${hikingColor}`}>   Hiking   </p>
  <span class = "font-bold" style={`color: ${flyingColor}`}>   Flying   </p>

<div id="elevation-container" class="w-full hidden mt-2">
  <canvas id="elevation-canvas" class="w-full rounded border border-gray-200 block" style="height:130px; cursor:crosshair"></canvas>
</div>


<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<script >
  import L from 'leaflet';

  const mapContainer = document.getElementById('flight-map')!;
  const mapLabel = document.getElementById('flight-map-label')!;
  const hikingColor = mapLabel.dataset.hikingc;
  const flyingColor = mapLabel.dataset.flyingc;

  const elevContainer = document.getElementById('elevation-container')!;
  const elevCanvas = document.getElementById('elevation-canvas') as HTMLCanvasElement;

  // Chart layout constants (pixels)
  const PL = 46, PR = 8, PT = 10, PB = 20;

  let map: L.Map | null = null;
  let layerGroup: L.LayerGroup | null = null;
  let posMarker: L.CircleMarker | null = null;
  let currentFixes: any[] = [];
  let currentIdx = 0;
  let dragging = false;

  function altOf(f: any): number {
    return f.pressureAltitude ?? f.gpsAltitude ?? 0;
  }

  function idxFromClientX(clientX: number): number {
    const rect = elevCanvas.getBoundingClientRect();
    const plotW = rect.width - PL - PR;
    const frac = Math.max(0, Math.min(1, (clientX - rect.left - PL) / plotW));
    return Math.round(frac * (currentFixes.length - 1));
  }

  function applyIdx(idx: number) {
    currentIdx = idx;
    drawElevation(currentFixes, idx);
    if (posMarker && currentFixes[idx]) {
      posMarker.setLatLng([currentFixes[idx].latitude, currentFixes[idx].longitude]);
    }
  }

  // Mouse events
  elevCanvas.addEventListener('mousedown', (e) => {
    if (!currentFixes.length) return;
    dragging = true;
    applyIdx(idxFromClientX(e.clientX));
  });
  document.addEventListener('mousemove', (e) => {
    if (dragging) applyIdx(idxFromClientX(e.clientX));
  });
  document.addEventListener('mouseup', () => { dragging = false; });

  // Touch events
  elevCanvas.addEventListener('touchstart', (e) => {
    if (!currentFixes.length) return;
    dragging = true;
    applyIdx(idxFromClientX(e.touches[0].clientX));
  }, { passive: true });
  document.addEventListener('touchmove', (e) => {
    if (dragging) applyIdx(idxFromClientX(e.touches[0].clientX));
  }, { passive: true });
  document.addEventListener('touchend', () => { dragging = false; });

  window.addEventListener('resize', () => {
    if (currentFixes.length) drawElevation(currentFixes, currentIdx);
  });

  function drawElevation(fixes: any[], cursorIdx: number) {
    const rect = elevCanvas.getBoundingClientRect();
    if (rect.width === 0) return;
    elevCanvas.width = Math.floor(rect.width);
    elevCanvas.height = Math.floor(rect.height);
    const ctx = elevCanvas.getContext('2d')!;
    const W = elevCanvas.width, H = elevCanvas.height;
    const plotW = W - PL - PR, plotH = H - PT - PB;

    const alts = fixes.map(altOf);
    const minAlt = Math.min(...alts);
    const maxAlt = Math.max(...alts);
    const range = maxAlt - minAlt || 1;

    const xOf = (i: number) => PL + (i / (fixes.length - 1)) * plotW;
    const yOf = (alt: number) => PT + plotH - ((alt - minAlt) / range) * plotH;

    // Background
    ctx.fillStyle = '#f9fafb';
    ctx.fillRect(0, 0, W, H);

    // Grid + Y-axis labels
    ctx.font = '10px sans-serif';
    ctx.textAlign = 'right';
    ctx.fillStyle = '#9ca3af';
    for (let i = 0; i <= 3; i++) {
      const alt = minAlt + (range * i) / 3;
      const y = yOf(alt);
      ctx.fillText(`${Math.round(alt)}m`, PL - 3, y + 3);
      ctx.strokeStyle = '#e5e7eb';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(PL, y);
      ctx.lineTo(W - PR, y);
      ctx.stroke();
    }

    // Area fill
    ctx.beginPath();
    ctx.moveTo(xOf(0), H - PB);
    fixes.forEach((f: any, i: number) => ctx.lineTo(xOf(i), yOf(altOf(f))));
    ctx.lineTo(xOf(fixes.length - 1), H - PB);
    ctx.closePath();
    ctx.fillStyle = 'rgba(0,27,255,0.07)';
    ctx.fill();

    // Colored line (ground vs flight)
    const hasState = fixes.some((f: any) => f.onGround !== undefined);
    if (hasState) {
      for (let i = 1; i < fixes.length; i++) {
        ctx.beginPath();
        ctx.moveTo(xOf(i - 1), yOf(altOf(fixes[i - 1])));
        ctx.lineTo(xOf(i), yOf(altOf(fixes[i])));
        ctx.strokeStyle = fixes[i].onGround ? (hikingColor ?? '#8856fc') : (flyingColor ?? '#001bff');
        ctx.lineWidth = 1.5;
        ctx.stroke();
      }
    } else {
      ctx.beginPath();
      fixes.forEach((f: any, i: number) => {
        if (i === 0) ctx.moveTo(xOf(0), yOf(altOf(f)));
        else ctx.lineTo(xOf(i), yOf(altOf(f)));
      });
      ctx.strokeStyle = flyingColor ?? '#001bff';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }

    // Cursor
    if (cursorIdx >= 0 && cursorIdx < fixes.length) {
      const cx = xOf(cursorIdx);
      const cy = yOf(altOf(fixes[cursorIdx]));

      ctx.setLineDash([4, 3]);
      ctx.strokeStyle = '#ef4444';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(cx, PT);
      ctx.lineTo(cx, H - PB);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.beginPath();
      ctx.arc(cx, cy, 4, 0, Math.PI * 2);
      ctx.fillStyle = '#ef4444';
      ctx.fill();

      const label = `${Math.round(altOf(fixes[cursorIdx]))}m`;
      ctx.font = 'bold 11px sans-serif';
      ctx.fillStyle = '#111827';
      ctx.textAlign = cx > W / 2 ? 'right' : 'left';
      ctx.fillText(label, cx + (cx > W / 2 ? -8 : 8), PT + 14);
    }
  }

  function initMap() {
    if (map) return;
    map = L.map(mapContainer).setView([0, 0], 2);
    L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
      attribution:
        '&copy; <a href="https://opentopomap.org">OpenTopoMap</a> contributors',
      maxZoom: 17,
    }).addTo(map);
    layerGroup = L.layerGroup().addTo(map);
  }

  function displayFlight(detail: any) {
    const flight = detail.flight;
    const dist = detail.groundDist;
    const { scoreInfo, opt } = detail.best;
    const { tp, cp, ep } = scoreInfo;

    mapContainer.classList.remove('hidden');
    mapLabel.classList.remove('hidden');
    elevContainer.classList.remove('hidden');
    initMap();
    layerGroup!.clearLayers();

    // Remove stale position marker from map (not layerGroup, so clearLayers won't touch it)
    if (posMarker) { posMarker.remove(); posMarker = null; }

    // Draw the flight track (drop invalid 0,0 GPS records)
    const fixes = (flight?.filtered || flight?.fixes)?.filter(
      (f: any) => f.latitude !== 0 || f.longitude !== 0
    );
    if (fixes?.length) {
      type Fix = {
        latitude: number;
        longitude: number;
        stateGround?: boolean;
        stateFlight?: boolean;
      };

      type Segment = {
        state: 'ground' | 'flight' | 'unknown';
        points: L.LatLngExpression[];
      };

      const segments: Segment[] = [];
      let currentState: Segment['state'] | null = null;
      let currentPoints: L.LatLngExpression[] = [];

      for (const fix of fixes as Fix[]) {
        const state: Segment['state'] = fix.onGround ? 'ground' : 'flight';

        if (state !== currentState) {
          if (currentPoints.length > 0) {
            segments.push({ state: currentState!, points: currentPoints });
            // overlap last point for continuity
            currentPoints = [currentPoints[currentPoints.length - 1]];
          }
          currentState = state;
        }
        currentPoints.push([fix.latitude, fix.longitude]);
      }
      if (currentPoints.length > 0) {
        segments.push({ state: currentState!, points: currentPoints });
      }

      const hasStateInfo = fixes.some(
        (f: any) => f.stateGround || f.stateFlight || f.onGround !== undefined
      );

      if (hasStateInfo) {
        const styleMap = {
          flight: { color: flyingColor, weight: 6, opacity: 1 },
          ground: { color: hikingColor, weight: 10, opacity: 1 },
          unknown: { color: '#f59e0b', weight: 8, opacity: 1 },
        };
        // Sort: ground first, then unknown, then flight (so flight renders on top)
        const sorted = [...segments].sort((a, b) => {
          const order = { ground: 0, unknown: 1, flight: 2 };
          return order[a.state] - order[b.state];
        });
        for (const seg of sorted)  {
          L.polyline(seg.points, styleMap[seg.state]).addTo(layerGroup!);
        }
      } else {
        // No state info available — draw uniform track
        const trackCoords: L.LatLngExpression[] = fixes.map(
          (fix: Fix) => [fix.latitude, fix.longitude] as L.LatLngExpression
        );
        L.polyline(trackCoords, {
          color: hikingColor,
          weight: 4,
          opacity: 0.5,
        }).addTo(layerGroup!);
      }
    }

    // Draw triangle / distance legs
    if (tp?.length) {
      const tpCoords: L.LatLngExpression[] = tp.map(
        (p: { x: number; y: number }) => [p.y, p.x] as L.LatLngExpression
      );

      // Close the shape if it's a triangle (has closing points)
      const shapeCoords = cp?.in ? [...tpCoords, tpCoords[0]] : tpCoords;

      L.polyline(shapeCoords, {
        color: '#000000',
        weight: 2.5,
        opacity: 0.9,
      }).addTo(layerGroup!);

      // Turnpoint markers
      tp.forEach((p: { x: number; y: number; r: number }, i: number) => {
        L.circleMarker([p.y, p.x], {
          radius: 7,
          color: '#fff',
          weight: 2,
          fillColor: '#22c55e',
          fillOpacity: 1,
        })
          .bindPopup(`<strong>TP ${i + 1}</strong><br>${p.y.toFixed(5)}, ${p.x.toFixed(5)}`)
          .addTo(layerGroup!);
      });
    }

    
    // Triangle closing points
    if (cp?.in) {
      L.circleMarker([cp.in.y, cp.in.x], {
        radius: 5,
        color: '#fff',
        weight: 2,
        fillColor: '#fd0500',
        fillOpacity: 1,
      })
        .bindPopup(`<strong>Close in</strong><br>${cp.in.y.toFixed(5)}, ${cp.in.x.toFixed(5)}`)
        .addTo(layerGroup!);

      L.circleMarker([cp.out.y, cp.out.x], {
        radius: 5,
        color: '#fff',
        weight: 2,
        fillColor: '#fd0500',
        fillOpacity: 1,
      })
        .bindPopup(`<strong>Close out</strong><br>${cp.out.y.toFixed(5)}, ${cp.out.x.toFixed(5)}`)
        .addTo(layerGroup!);

      // Closing distance line
      L.polyline(
        [
          [cp.in.y, cp.in.x],
          [cp.out.y, cp.out.x],
        ],
        { color: '#f97316', weight: 1.5, dashArray: '6 4' }
      ).addTo(layerGroup!);
    }

    // Fit map to content
    const allBounds: L.LatLngExpression[] = [];
    if (tp?.length) tp.forEach((p: { x: number; y: number }) => allBounds.push([p.y, p.x]));
    if (cp?.in) {
      allBounds.push([cp.in.y, cp.in.x]);
      allBounds.push([cp.out.y, cp.out.x]);
    }
    if (ep?.start) {
      allBounds.push([ep.start.y, ep.start.x]);
      allBounds.push([ep.finish.y, ep.finish.x]);
    }
    // Fall back to track fixes for bounds
    if (allBounds.length < 2 && fixes?.length) {
      for (const fix of fixes as { latitude: number; longitude: number }[]) {
        allBounds.push([fix.latitude, fix.longitude]);
      }
    }

    if (allBounds.length >= 2) {
      map!.fitBounds(L.latLngBounds(allBounds), { padding: [40, 40] });
    }

    // Elevation plot + position marker
    if (fixes?.length) {
      currentFixes = fixes;
      currentIdx = 0;

      posMarker = L.circleMarker([fixes[0].latitude, fixes[0].longitude], {
        radius: 6,
        color: '#ef4444',
        weight: 2,
        fillColor: '#ef4444',
        fillOpacity: 0.85,
      }).addTo(map!);

      // Draw after layout settles so getBoundingClientRect has real dimensions
      setTimeout(() => drawElevation(fixes, 0), 150);
    }

    // Fix tile rendering after container becomes visible
    setTimeout(() => map!.invalidateSize(), 100);
  }

  // Listen for events from IgcScorer
  document.addEventListener('igc-score-result', ((e: CustomEvent) => {
    displayFlight(e.detail);
  }) as EventListener);
</script>