{
  "name": "tracklog-handler",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "process": "node dist/process.js",
    "archive-prologue": "node --env-file=.env dist/archive_prologue.js",
    "rescore": "node --env-file=.env dist/rescore_all.js",
    "rescore:local": "node --env-file=.env --env-file=../.env.local dist/rescore_all.js",
    "sync-local": "node --env-file=.env --env-file=../.env.local dist/sync_from_r2.js",
    "reset": "node --env-file=.env dist/reset_scores.js",
    "test": "node dist/run_tests.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "igc-parser": "^1.1.0",
    "igc-xc-score": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
